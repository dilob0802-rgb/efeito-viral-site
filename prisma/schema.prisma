generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id            String   @id @default(cuid())
  nome          String
  perfilSocial  String
  desafios      String
  createdAt     DateTime @default(now())
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  password           String
  role               Role      @default(USER)
  
  // Dados do Perfil (Onboarding)
  niche              String?
  subscribers        String?
  mainGoal           String?
  painPoints         String?   // Salvo como string separada por vírgula ou JSON
  selectedMentor     String?
  onboardingComplete Boolean   @default(false)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  competitors        Competitor[]
}

enum Role {
  USER
  ADMIN
}

model Competitor {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  username        String
  platform        String   // instagram, tiktok, youtube
  followersCount  Int?
  engagementRate  Float?
  lastAnalysed    DateTime?
  createdAt       DateTime @default(now())
  analyses        Analysis[]

  @@unique([userId, username, platform])
}

model Analysis {
  id              String   @id @default(cuid())
  competitorId    String
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  type            String   // viral_posts, strategy_xray, action_plan
  data            String   // JSON string with the analysis results
  createdAt       DateTime @default(now())
}
