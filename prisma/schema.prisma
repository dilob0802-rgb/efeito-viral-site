generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id            String   @id @default(cuid())
  nome          String
  perfilSocial  String
  desafios      String
  createdAt     DateTime @default(now())
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  password           String
  role               String    @default("USER") // USER, ADMIN
  
  // Dados do Perfil (Onboarding)
  niche              String?
  subscribers        String?
  viewCount          String?
  videoCount         String?
  mainGoal           String?
  painPoints         String?   // Salvo como string separada por vírgula ou JSON
  selectedMentor     String?
  
  // Dados do Canal Conectado
  youtubeChannelId     String?
  youtubeChannelName   String?
  youtubeChannelAvatar String?
  
  // Chaves Privadas de Analytics do Google OAuth
  googleAccessToken    String?
  googleRefreshToken   String?
  
  isPremium          Boolean   @default(false)
  plan               String    @default("FREE") // FREE, PREMIUM

  onboardingComplete Boolean   @default(false)
  whatsapp           String?   // Para contato direto do suporte/admin

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  competitors        Competitor[]
  youtubeChannels    YoutubeChannel[]
  orders             Order[]
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String   @default("BRL")
  status        String   // COMPLETED, PENDING, FAILED
  paypalId      String?  @unique
  couponCode    String?
  createdAt     DateTime @default(now())
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountType    String   // PERCENTAGE, FIXED
  discountValue   Float
  usageCount      Int      @default(0)
  maxUsage        Int?
  isActive        Boolean  @default(true)
  influencerId    String?
  influencer      Influencer? @relation(fields: [influencerId], references: [id])
  createdAt       DateTime @default(now())
}

model Influencer {
  id              String   @id @default(cuid())
  name            String
  socialHandle    String?
  whatsapp        String?
  commissionRate  Float    @default(0) // Porcentagem de comissão por venda
  coupons         Coupon[]
  createdAt       DateTime @default(now())
}

model YoutubeChannel {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId       String
  channelName     String
  channelAvatar   String?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([userId, channelId])
}

model Competitor {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  username        String
  platform        String   // instagram, tiktok, youtube
  followersCount  Int?
  engagementRate  Float?
  lastAnalysed    DateTime?
  createdAt       DateTime @default(now())
  analyses        Analysis[]

  @@unique([userId, username, platform])
}

model Analysis {
  id              String   @id @default(cuid())
  competitorId    String
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  type            String   // viral_posts, strategy_xray, action_plan
  data            String   // JSON string with the analysis results
  createdAt       DateTime @default(now())
}
